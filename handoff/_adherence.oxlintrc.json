{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "apps/maestro/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/overlays/**",
              "components/work/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:CalSans))/i]",
        "message": "Font not provided by the design system. Available: CalSans."
      },
      {
        "selector": "JSXOpeningElement[name.name='AutonomySegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:start|width|live|key|ref|className|style|children)$/]",
        "message": "<AutonomySegment> doesn't accept that prop. Declared props: start, width, live."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|size|src|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, color, size, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|soft|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|running|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, running, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|children|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandPaletteItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|title|meta|icon|kbd|key|ref|className|style|children)$/]",
        "message": "<CommandPaletteItem> doesn't accept that prop. Declared props: id, title, meta, icon, kbd."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|onSend|leading|key|ref|className|style|children)$/]",
        "message": "<Composer> doesn't accept that prop. Declared props: placeholder, value, onChange, onSend, leading."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|actions|onClose|width|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, children, actions, onClose, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DotComet'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|key|ref|className|style|children)$/]",
        "message": "<DotComet> doesn't accept that prop. Declared props: size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|children|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, hint, error, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LifecycleStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|state|note|key|ref|className|style|children)$/]",
        "message": "<LifecycleStage> doesn't accept that prop. Declared props: name, state, note."
      },
      {
        "selector": "JSXOpeningElement[name.name='LifecycleStage'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:passed|current|warn|upcoming)$/]",
        "message": "<LifecycleStage> state must be one of 'passed' | 'current' | 'warn' | 'upcoming'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Menu'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|minWidth|style|key|ref|className|style|children)$/]",
        "message": "<Menu> doesn't accept that prop. Declared props: children, minWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|children|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReceiptRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|code|style|key|ref|className|style|children)$/]",
        "message": "<ReceiptRow> doesn't accept that prop. Declared props: icon, label, code, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|agent|duration|title|decided|asks|receipts|onApprove|onSendBack|style|key|ref|className|style|children)$/]",
        "message": "<RunCard> doesn't accept that prop. Declared props: state, agent, duration, title, decided, asks, receipts, onApprove, onSendBack, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunCard'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:queued|running|stuck|needs-you|done|standing)$/]",
        "message": "<RunCard> state must be one of 'queued' | 'running' | 'stuck' | 'needs-you' | 'done' | 'standing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Segmented'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Segmented> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|placeholder|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, placeholder."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|pulse|children|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, pulse, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|info|warning|danger|neutral)$/]",
        "message": "<StatusBadge> status must be one of 'success' | 'info' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|defaultActive|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, defaultActive, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|title|meta|action|onAction|onDismiss|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: status, title, meta, action, onAction, onDismiss, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:success|info|warning|danger|neutral)$/]",
        "message": "<Toast> status must be one of 'success' | 'info' | 'warning' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|side|children|style|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, side, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> side must be one of 'top' | 'bottom' | 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Undertow'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|children|style|key|ref|className|style|children)$/]",
        "message": "<Undertow> doesn't accept that prop. Declared props: active, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkState'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|variant|children|style|key|ref|className|style|children)$/]",
        "message": "<WorkState> doesn't accept that prop. Declared props: state, variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkState'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:queued|running|stuck|needs-you|done|standing)$/]",
        "message": "<WorkState> state must be one of 'queued' | 'running' | 'stuck' | 'needs-you' | 'done' | 'standing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WorkState'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:inline|chip)$/]",
        "message": "<WorkState> variant must be one of 'inline' | 'chip'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
