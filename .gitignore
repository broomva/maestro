# checkout's _work.md copies are never indexed as duplicate nodes); receipts live under runs/run-<id>/.
/.maestro/
/runs/

# Machine-local control telemetry (bstack — wired in BRO-1829)
.control/audit/*.jsonl
.control/leverage-*.json
.control/leverage-*.jsonl
